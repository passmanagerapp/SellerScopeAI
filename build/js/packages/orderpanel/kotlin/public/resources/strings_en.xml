    <string name="idxFeaturesLabel">Everything you need</string>
    <string name="idxFeaturesTitle">Built for order-driven businesses</string>
    <string name="idxFeaturesSubtitle">One dashboard. All your orders, profit data and shipping in one place — no spreadsheets needed.</string>
    <string name="idxFeat1Title">Order Management</string>
    <string name="idxFeat1Desc">Create, track and update orders in real time. Full edit, clone and delete support with inline editing.</string>
    <string name="idxFeat2Title">Interactive Analytics</string>
    <string name="idxFeat2Desc">Beautiful donut charts and bar graphs showing profit breakdown, country distribution and cost analysis.</string>
    <string name="idxFeat3Title">Shipping Tracking</string>
    <string name="idxFeat3Desc">Integrated UPS tracking links per order. Know exactly where every package is at any moment.</string>
    <string name="idxFeat4Title">Financial Reports</string>
    <string name="idxFeat4Desc">Gross profit, net profit, shipping cost, tariffs and product cost — all auto-calculated per order and per month.</string>
    <string name="idxFeat5Title">Smart Search &amp; Filters</string>
    <string name="idxFeat5Desc">Filter by status, search by name, sort by date or revenue. Find any order in seconds.</string>
    <string name="idxFeat6Title">SKU Management</string>
    <string name="idxFeat6Desc">Configure product costs per SKU. The dashboard auto-fills product cost when you select a SKU on a new order.</string>

